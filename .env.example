# Database Configuration (Required)
DATABASE_URL="file:./prisma/dev.db"
# For PostgreSQL: DATABASE_URL="postgresql://username:password@localhost:5432/database_name"
# For MySQL: DATABASE_URL="mysql://username:password@localhost:3306/database_name"

# Next.js Configuration
NODE_ENV="production"
NEXTAUTH_URL="https://yourdomain.com"
NEXTAUTH_SECRET="your-secret-key-here"

# Optional: Supabase Configuration (if using Supabase features)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Optional: Email Configuration (if using email features)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
